# =============================================================================
# VietAgent Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Google APIs (Sheets, Slides, Drive) ---
# OAuth credentials file path (default: credentials.json in project root)
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json

# --- Modal (Cloud Webhooks) ---
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# --- Slack (Webhook Activity Streaming) ---
SLACK_WEBHOOK_URL=

# --- Email (for send_email webhook tool) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# --- OpenAI (if needed for embedding/other tasks) ---
OPENAI_API_KEY=

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Cloud TTS ---
GOOGLE_TTS_API_KEY=
